---
import type { Language } from '@/i18n/config'
import { getTagPath } from '@/i18n/path'

interface Props {
  tags: string[]
  currentTag?: string
  lang: Language
}

const { tags, currentTag = '', lang } = Astro.props
---

<div class="tag-list no-heti mb-10.5 flex flex-wrap gap-x-3 gap-y-3.2">
  {tags.map(tag => (
    <a
      href={getTagPath(tag, lang)}
      aria-current={currentTag === tag ? 'page' : undefined}
      class:list={[
        'relative inline-block px-2 py-1.5 transition-colors ease-out',
        currentTag === tag ? 'c-primary' : '',
      ]}
    >
      <span class="whitespace-nowrap">{tag}</span>
    </a>
  ))}
</div>

<style>
  .tag-list a::after {
    position: absolute;
    right: 0.5rem;
    bottom: 0.2rem;
    left: 0.5rem;
    height: 1px;
    background-color: oklch(var(--un-preset-theme-colors-primary) / 1);
    content: '';
    opacity: 0;
    transform: scaleX(0.35);
    transform-origin: left;
    transition: opacity 180ms ease-out, transform 180ms ease-out;
  }

  .tag-list a:hover::after,
  .tag-list a:focus-visible::after {
    opacity: 0.75;
    transform: scaleX(1);
  }

  .tag-list a[aria-current='page']::after {
    right: 0.5rem;
    left: 0.5rem;
    width: auto;
    background-color: oklch(var(--un-preset-theme-colors-accent) / 1);
    opacity: 0.75;
    transform: scaleX(1);
  }

  .tag-list a:focus-visible {
    outline: 1px solid oklch(var(--un-preset-theme-colors-primary) / 1);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .tag-list a::after {
      transition: none;
    }
  }
</style>
